{
  "_comment": "Source de vérité du thème CinePick. Ne jamais hardcoder ces valeurs dans les composants. Modifier ici pour changer tout le thème.",

  "colors": {
    "bg": "#141928",
    "surface": "#1c2438",
    "surfaceAlt": "#202840",
    "border": "#1c243e",
    "borderSubtle": "#161e36",
    "accent": "#8faae8",
    "accentDark": "#6688cc",
    "accentMuted": "rgba(143,170,232,0.10)",
    "text": "#ccd4ec",
    "textMuted": "#404e80",
    "textSubtle": "#303a60",
    "textDisabled": "#1c243e",
    "success": "#00f5a0",
    "error": "#ff6b6b",
    "errorMuted": "rgba(255,107,107,0.1)",
    "swipeAccept": "#4ecdc4",
    "swipeReject": "#ff6b6b"
  },

  "fonts": {
    "display": "serif",
    "mono": "monospace",
    "body": "System"
  },

  "fontSizes": {
    "xs": 10,
    "sm": 12,
    "base": 14,
    "md": 16,
    "lg": 20,
    "xl": 24,
    "xxl": 32,
    "display": 40
  },

  "fontWeights": {
    "regular": "400",
    "medium": "500",
    "semibold": "600",
    "bold": "700",
    "extrabold": "800"
  },

  "lineHeights": {
    "tight": 1.2,
    "normal": 1.5,
    "relaxed": 1.7
  },

  "letterSpacing": {
    "tight": -0.3,
    "normal": 0,
    "wide": 0.5,
    "wider": 1.5,
    "caps": 2
  },

  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "screen": 20
  },

  "radius": {
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 20,
    "full": 9999
  },

  "shadows": {
    "card": {
      "shadowColor": "#000",
      "shadowOffset": { "width": 0, "height": 8 },
      "shadowOpacity": 0.4,
      "shadowRadius": 20,
      "elevation": 10
    },
    "subtle": {
      "shadowColor": "#000",
      "shadowOffset": { "width": 0, "height": 2 },
      "shadowOpacity": 0.2,
      "shadowRadius": 8,
      "elevation": 3
    }
  },

  "animation": {
    "fast": 150,
    "normal": 250,
    "slow": 400,
    "spring": {
      "tension": 60,
      "friction": 9
    }
  },

  "swipe": {
    "threshold": 0.25,
    "rotationDeg": 8
  }
}
